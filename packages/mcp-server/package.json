{
  "name": "spacetimedb-memory-mmo-mcp-server",
  "version": "0.0.1",
  "description": "MCP server bridging AI agents to a compound-memory SpacetimeDB module",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spacetimedb-memory-mmo-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TheJoeJep/SpacetimeDB-Memory-MMO.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/TheJoeJep/SpacetimeDB-Memory-MMO/tree/main/packages/mcp-server#readme",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "spacetimedb": "^2.2.0",
    "ws": "^8.18.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
