{
  "name": "spacetimedb-memory-mmo",
  "version": "0.0.1",
  "description": "Multi-agent compound memory for AI agents, backed by SpacetimeDB",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spacetimedb-memory-mmo": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TheJoeJep/SpacetimeDB-Memory-MMO.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/TheJoeJep/SpacetimeDB-Memory-MMO#readme",
  "bugs": {
    "url": "https://github.com/TheJoeJep/SpacetimeDB-Memory-MMO/issues"
  },
  "keywords": [
    "spacetimedb",
    "memory",
    "mcp",
    "ai-agents",
    "claude",
    "cursor",
    "compound-memory"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "sync:templates": "node scripts/sync-templates.mjs",
    "build": "npm run sync:templates && esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "execa": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
